rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidGame(data) {
      return data.keys().hasAll(['userId', 'title', 'category', 'visibility', 'createdAt', 'updatedAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.title is string && data.title.size() <= 200 && data.title.size() > 0
        && data.category is string && data.category.size() <= 100
        && data.visibility == 'public'
        && ( !('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1048487) )
        && ( !('startDate' in data) || data.startDate == null || (data.startDate is string && data.startDate.size() <= 50) )
        && ( !('endDate' in data) || data.endDate == null || (data.endDate is string && data.endDate.size() <= 50) )
        && ( !('status' in data) || (data.status is string && data.status.size() <= 50) )
        && ( !('rating' in data) || data.rating == null || data.rating is number );
    }

    match /games/{gameId} {
      allow read: if true;
      allow list: if true;
      
      allow create: if isValidId(gameId)
        && isValidGame(incoming())
        // Strict keys
        && incoming().keys().size() >= 6 && incoming().keys().size() <= 11
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isValidGame(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          incoming().diff(existing()).affectedKeys().hasOnly([
            'title', 'category', 'imageUrl', 'startDate', 'endDate', 'status', 'rating', 'updatedAt', 'userId'
          ])
        );

      allow delete: if isValidId(gameId);
    }
  }
}
